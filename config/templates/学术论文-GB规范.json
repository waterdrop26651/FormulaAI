{
    "name": "学术论文-GB规范",
    "description": "符合GB/T 7713国家标准的学术论文格式",
    "rules": {
        "论文标题": {
            "font": "黑体",
            "size": "小二",
            "bold": true,
            "alignment": "center"
        },
        "作者信息": {
            "font": "楷体",
            "size": "小四",
            "bold": false,
            "alignment": "center"
        },
        "摘要标题": {
            "font": "黑体",
            "size": "小三",
            "bold": true,
            "alignment": "center"
        },
        "摘要内容": {
            "font": "宋体",
            "size": "小四",
            "bold": false,
            "alignment": "左对齐"
        },
        "关键词": {
            "font": "宋体",
            "size": "小四",
            "bold": false,
            "alignment": "左对齐"
        },
        "一级标题": {
            "font": "黑体",
            "size": "小三",
            "bold": true,
            "alignment": "左对齐"
        },
        "二级标题": {
            "font": "黑体",
            "size": "四号",
            "bold": true,
            "alignment": "左对齐"
        },
        "三级标题": {
            "font": "黑体",
            "size": "小四",
            "bold": true,
            "alignment": "左对齐"
        },
        "正文": {
            "font": "宋体",
            "size": "小四",
            "bold": false,
            "alignment": "两端对齐"
        },
        "图表标题": {
            "font": "宋体",
            "size": "五号",
            "bold": false,
            "alignment": "居中"
        },
        "参考文献": {
            "font": "宋体",
            "size": "五号",
            "bold": false,
            "alignment": "左对齐"
        }
    }
}
