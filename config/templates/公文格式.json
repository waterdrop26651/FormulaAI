        "附件说明": {
            "font": "仿宋",
            "size": "三号",
            "bold": false,
            "alignment": "左对齐"
        },
        "落款": {
            "font": "仿宋",
            "size": "三号",
            "bold": false,
            "alignment": "右对齐"
        },
        "成文日期": {
            "font": "仿宋",
            "size": "三号",
            "bold": false,
            "alignment": "右对齐"
        }
