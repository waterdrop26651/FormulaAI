{
    "name": "科技报告",
    "description": "科技报告/技术文档格式",
    "rules": {
        "报告标题": {
            "font": "黑体",
            "size": "二号",
            "bold": true,
            "alignment": "居中"
        },
        "副标题": {
            "font": "楷体",
            "size": "三号",
            "bold": false,
            "alignment": "居中"
        },
        "作者信息": {
            "font": "宋体",
            "size": "四号",
            "bold": false,
            "alignment": "居中"
        },
        "摘要": {
            "font": "宋体",
            "size": "小四",
            "bold": false,
            "alignment": "两端对齐"
        },
        "一级标题": {
            "font": "黑体",
            "size": "四号",
            "bold": true,
            "alignment": "左对齐"
        },
        "二级标题": {
            "font": "黑体",
            "size": "小四",
            "bold": true,
            "alignment": "左对齐"
        },
        "三级标题": {
            "font": "宋体",
            "size": "小四",
            "bold": true,
            "alignment": "左对齐"
        },
        "正文": {
            "font": "宋体",
            "size": "小四",
            "bold": false,
            "alignment": "两端对齐"
        },
        "代码块": {
            "font": "Courier New",
            "size": "小四",
            "bold": false,
            "alignment": "左对齐"
        },
        "图表说明": {
            "font": "宋体",
            "size": "五号",
            "bold": false,
            "alignment": "居中"
        },
        "参考文献": {
            "font": "宋体",
            "size": "小四",
            "bold": false,
            "alignment": "左对齐"
        }
    }
}
